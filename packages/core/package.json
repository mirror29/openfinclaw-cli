{
  "name": "@openfinclaw/core",
  "version": "0.5.1",
  "description": "Core logic for OpenFinClaw — DeepAgent client, strategy tools & shared types",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirror29/openfinclaw-cli.git",
    "directory": "packages/core"
  },
  "keywords": [
    "openfinclaw",
    "deepagent",
    "quant",
    "trading-agent",
    "financial",
    "mcp",
    "strategy",
    "backtest",
    "paper-trading"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "typescript": "^5.7.0"
  }
}
